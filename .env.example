# Copy to .env (or .env.local) and fill in.
# Vite exposes only VITE_* prefixed vars to the client.

# Google OAuth Client ID for Drive sync.
# Create at https://console.cloud.google.com → APIs & Services → Credentials.
# See legacy/cihai-deployment-guide.md for full setup.
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# LLM endpoint for quick-add word enrichment.
# Dev only — for production, proxy through a server function (see lib/llm-enrich.ts).
VITE_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
VITE_LLM_API_KEY=sk-...
VITE_LLM_MODEL=gpt-4o-mini

# Supabase cross-device sync (optional). The anon key is a public client key.
# Easiest to set these in-app (词库 → 云同步); env is just a dev convenience.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
