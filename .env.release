# Public-release build flags (used by `npm run build:release`).
# Hides dev/maintenance plumbing. Does NOT contain any secret — safe to commit.
# (Your own Supabase URL + anon key, if baked for one-tap login, also go in a
#  release env; the anon key is public-by-design and protected by RLS.)
VITE_RELEASE=1
